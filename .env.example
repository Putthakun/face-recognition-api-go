# Database (SQL Server)
DB_HOST=infra-sqlserver
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourStrong@Password
DB_NAME=facerecog

# Redis
REDIS_ADDR=infra-redis:6379
REDIS_PASSWORD=yourredispassword

# JWT
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_ISSUER=face-recognition-api-go
JWT_AUDIENCE=face-recognition-client

# Face server (face-recognition-server)
FACE_API_BASE_URL=http://face-server:8001

# Admin seed (first run only)
ADMIN_PASSWORD=Admin@1234

# CORS
ALLOWED_ORIGIN=http://localhost:5173

# Server
PORT=8080
